
<launch>

<arg name="enable_network_monitor" default="true" />

<include file="$(find pick_place)/launch/kortex_driver.launch">
    <arg name="start_rviz" value="false" />
</include>
<include file="$(find pick_place)/launch/kinova_vision_rgbd.launch" />
<include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch">
    <arg name="port" value="9090" />
</include>

<!-- Dedicated rosbridge for base camera streaming -->
<node pkg="rosbridge_server" type="rosbridge_websocket" name="rosbridge_websocket_cam" output="screen">
    <param name="port" value="9091" />
    <param name="address" value="" />
    <param name="unregister_timeout" value="86400" />
</node>

<!-- Dedicated rosbridge for arm camera streaming -->
<node pkg="rosbridge_server" type="rosbridge_websocket" name="rosbridge_websocket_arm_cam" output="screen">
    <param name="port" value="9092" />
    <param name="address" value="" />
    <param name="unregister_timeout" value="86400" />
</node>

<!-- <node pkg="web_video_server" type="web_video_server" name="web_video_server" output="screen" /> -->

<node pkg="pick_place" type="main.py" name="pick_place" output="screen" />

<!-- Phase 0: Network Quality Monitor
     Disable with: roslaunch pick_place pick_place.launch enable_network_monitor:=false -->
<group if="$(arg enable_network_monitor)">
    <!-- Relay: echos /network_probe_ping → /network_probe_pong so the browser
         round-trip traverses the real rosbridge WebSocket path -->
    <node pkg="pick_place" type="network_probe_relay.py"
          name="network_probe_relay" output="screen" />
    <!-- Monitor: aggregates /browser_rtt_ms samples and publishes /network_quality -->
    <node pkg="pick_place" type="network_monitor_node.py"
          name="network_monitor_node" output="screen" />
</group>

<!-- Start rviz using pick_place.rviz -->
<node pkg="rviz" type="rviz" name="rviz" args="-d $(find pick_place)/pick_place.rviz" output="screen" />

</launch>

