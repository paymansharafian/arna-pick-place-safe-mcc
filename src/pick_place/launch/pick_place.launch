
<launch>

<arg name="enable_network_monitor"  default="true" />
  <arg name="enable_network_watchdog" default="true" />
  <arg name="enable_operator_intent"  default="true" />

<!-- Phase 1: MPC-CBF arm safety filter
     When true:  mpc_cbf_arm_node filters /my_gen3/in/cartesian_velocity_desired
                 → /my_gen3/in/cartesian_velocity using full MPC-CBF with CasADi.
     When false: arm_cmd_passthrough_node relays the topic verbatim (zero processing).
     Exactly one of the two nodes is always running — no commands are silently dropped.
     Override: roslaunch pick_place pick_place.launch enable_mpc_cbf:=false -->
<arg name="enable_mpc_cbf" default="true" />

<include file="$(find pick_place)/launch/kortex_driver.launch">
    <arg name="start_rviz" value="false" />
</include>
<include file="$(find pick_place)/launch/kinova_vision_rgbd.launch" />
<include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch">
    <arg name="port" value="9090" />
</include>

<!-- Dedicated rosbridge for base camera streaming -->
<node pkg="rosbridge_server" type="rosbridge_websocket" name="rosbridge_websocket_cam" output="screen">
    <param name="port" value="9091" />
    <param name="address" value="" />
    <param name="unregister_timeout" value="86400" />
</node>

<!-- Dedicated rosbridge for arm camera streaming -->
<node pkg="rosbridge_server" type="rosbridge_websocket" name="rosbridge_websocket_arm_cam" output="screen">
    <param name="port" value="9092" />
    <param name="address" value="" />
    <param name="unregister_timeout" value="86400" />
</node>

<!-- <node pkg="web_video_server" type="web_video_server" name="web_video_server" output="screen" /> -->

<node pkg="pick_place" type="main.py" name="pick_place" output="screen" />

<!-- Phase 1: Arm velocity safety filter (exactly one branch active at all times) -->
<group if="$(arg enable_mpc_cbf)">
    <node pkg="pick_place" type="mpc_cbf_arm_node.py"
          name="mpc_cbf_arm_node" output="screen">
        <!-- All tuning parameters loaded from mpc_cbf_params.yaml.
             Override individual values here if needed. -->
        <rosparam command="load"
                  file="$(find pick_place)/config/mpc_cbf_params.yaml" />
    </node>
</group>
<group unless="$(arg enable_mpc_cbf)">
    <node pkg="pick_place" type="arm_cmd_passthrough_node.py"
          name="arm_cmd_passthrough_node" output="screen" />
</group>

<!-- Phase 0: Network Quality Monitor
     Disable with: roslaunch pick_place pick_place.launch enable_network_monitor:=false -->
<group if="$(arg enable_network_monitor)">
    <!-- Relay: echos /network_probe_ping → /network_probe_pong so the browser
         round-trip traverses the real rosbridge WebSocket path -->
    <node pkg="pick_place" type="network_probe_relay.py"
          name="network_probe_relay" output="screen" />
    <!-- Monitor: aggregates /browser_rtt_ms samples and publishes /network_quality -->
    <node pkg="pick_place" type="network_monitor_node.py"
          name="network_monitor_node" output="screen" />
    <!-- Phase 3: Network watchdog — coordinates adaptive behaviour of
         Phases 1 and 2 via dynamic_reconfigure on state transitions.
         Disable with: roslaunch pick_place pick_place.launch enable_network_watchdog:=false -->
    <group if="$(arg enable_network_watchdog)">
        <node pkg="pick_place" type="network_watchdog_node.py"
              name="network_watchdog_node" output="screen" />
    </group>
</group>

<!-- Phase 4: Operator intent — adaptive λ via scalar-α Boltzmann model + PGD.
     Disable with: roslaunch pick_place pick_place.launch enable_operator_intent:=false -->
<group if="$(arg enable_operator_intent)">
    <node pkg="pick_place" type="operator_intent_node.py"
          name="operator_intent_node" output="screen" />
</group>

<!-- Start rviz using pick_place.rviz -->
<node pkg="rviz" type="rviz" name="rviz" args="-d $(find pick_place)/pick_place.rviz" output="screen" />

</launch>

